{
  "name": "ebay-mcp",
  "version": "1.8.10",
  "description": "Model Context Protocol (MCP) server that exposes 100% of eBay's Sell APIs (332 tools across 270 endpoints) to AI assistants like Claude, Cursor, and Cline, covering inventory, order fulfillment, marketing, analytics, and developer tools with OAuth authentication and refresh-token support.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "ebay-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "setup": "tsx src/scripts/setup.ts",
    "sync": "tsx src/scripts/dev-sync.ts",
    "diagnose": "tsx src/scripts/diagnostics.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . && prettier --check \"src/**/*.{ts,js,json,md}\"",
    "fix": "eslint . --fix && prettier --write \"src/**/*.{ts,js,json,md}\"",
    "prepare": "npm run build && husky"
  },
  "keywords": [
    "mcp",
    "ebay",
    "ebay-api",
    "model-context-protocol",
    "ai-tools",
    "ai",
    "llm",
    "documentation",
    "api",
    "server",
    "backend"
  ],
  "author": "Yosef Hayim Sabag",
  "license": "MIT",
  "files": [
    "build/index.js",
    "build/server-http.js",
    "build/api/**/*.js",
    "build/auth/**/*.js",
    "build/config/**/*.js",
    "build/mcp/**/*.js",
    "build/schemas/**/*.js",
    "build/scripts/**/*.js",
    "build/tools/**/*.js",
    "build/utils/**/*.js",
    "build/types/index.js",
    "build/types/ebay.js",
    "build/types/ebay-enums.js",
    "build/index.d.ts",
    "build/server-http.d.ts",
    "public/icons/*.png",
    "README.md",
    "docs/auth/production_scopes.json",
    "docs/auth/sandbox_scopes.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YosefHayim/ebay-mcp.git"
  },
  "homepage": "https://github.com/YosefHayim/ebay-mcp#readme",
  "bugs": {
    "url": "https://github.com/YosefHayim/ebay-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "dotenv-stringify": "^3.0.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.0",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "nock": "^14.0.15",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "yaml": ">=2.8.3"
    }
  }
}
