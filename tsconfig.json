{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./build",
    "rootDir": "./src",
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "paths": { "@/*": ["./src/*"] },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "docs",
    "tests",
    "vitest.config.ts",
    "src/types/ebay/sell/marketing-and-promotions/marketing-response-types.ts",
    "src/types/ebay/sell/marketing-and-promotions/marketing-api-types.ts",
    "src/types/ebay/sell/order-management/dispute-types.ts"
  ]
}
